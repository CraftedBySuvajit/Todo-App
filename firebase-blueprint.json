{
  "entities": {
    "Task": {
      "title": "Task",
      "description": "An actionable item or goal.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "status": { "type": "string", "enum": ["todo", "in-progress", "completed"] },
        "priority": { "type": "string", "enum": ["low", "medium", "high"] },
        "tags": { "type": "array", "items": { "type": "string" } },
        "notes": { "type": "string" },
        "subTasks": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" },
              "isCompleted": { "type": "boolean" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" }
      },
      "required": ["title", "status", "priority", "userId", "createdAt"]
    }
  },
  "firestore": {
    "tasks/{taskId}": {
      "schema": "Task",
      "description": "User specific tasks."
    }
  }
}
